    <template id="s_banner_carousel" name="Impact Africa Banner Carousel">
        <section class="s_impact_banner_carousel" data-snippet="theme_impact_africa.s_banner_carousel" data-name="Banner Carousel">
            <div class="impact-banner-carousel" data-impact-carousel="true" data-interval="5600">
                <div class="impact-banner-carousel__viewport">
                    <article class="impact-banner-slide is-active" data-impact-slide="0" aria-hidden="false">
                        <img class="impact-banner-slide__image" src="https://images.unsplash.com/photo-1627141234469-24711efb373c?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wxMjA3fDB8MXxzZWFyY2h8Mnx8bW9kZXJuJTIwaG91c2UlMjBhcmNoaXRlY3R1cmV8ZW58MHx8fHwxNzcyOTc0MDY1fDA&amp;ixlib=rb-4.1.0&amp;q=80&amp;w=1600" alt="Maison moderne en architecture contemporaine"/>
                        <div class="impact-banner-slide__shade"></div>
                        <div class="impact-banner-slide__inner">
                            <div class="impact-banner-slide__content">
                                <span class="impact-banner-slide__eyebrow">Menuiserie Aluminium</span>
                                <h2>Des lignes nettes,<br /><em>une finition premium</em></h2>
                                <p>Pour les villas, immeubles et projets d'exception, Impact Africa fournit des solutions aluminium et vitrage conçues pour durer et valoriser l'architecture.</p>
                            </div>
                            <div class="impact-banner-slide__rail">
                                <a href="/services">Voir nos gammes aluminium</a>
                                <a href="/partenaires">Références de chantiers livrés</a>
                                <a href="/contact">Obtenir un devis pour votre projet</a>
                            </div>
                        </div>
                    </article>
                    <article class="impact-banner-slide" data-impact-slide="1" aria-hidden="true">
                        <img class="impact-banner-slide__image" src="https://images.unsplash.com/photo-1707823945934-bd0e46f4a612?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wxMjA3fDB8MXxzZWFyY2h8Mnx8Z2xhc3MlMjBvZmZpY2UlMjBidWlsZGluZyUyMGZhY2FkZXxlbnwwfHx8fDE3NzI5NzQwNjd8MA&amp;ixlib=rb-4.1.0&amp;q=80&amp;w=1600" alt="Façade de bureaux en verre et aluminium"/>
                        <div class="impact-banner-slide__shade"></div>
                        <div class="impact-banner-slide__inner">
                            <div class="impact-banner-slide__content">
                                <span class="impact-banner-slide__eyebrow">Façades &amp; Corporate</span>
                                <h2>Des façades qui affirment<br /><em>votre signature</em></h2>
                                <p>Des systèmes pensés pour les bâtiments professionnels, avec des profils robustes, une lecture architecturale claire et un rendu haut de gamme.</p>
                            </div>
                            <div class="impact-banner-slide__rail">
                                <a href="/services">Solutions façades et vitrages</a>
                                <a href="/partenaires">Voir nos partenaires BTP</a>
                                <a href="/contact">Parler à notre équipe technique</a>
                            </div>
                        </div>
                    </article>
                    <article class="impact-banner-slide" data-impact-slide="2" aria-hidden="true">
                        <img class="impact-banner-slide__image" src="https://images.unsplash.com/photo-1760072513403-d70003481414?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wxMjA3fDB8MXxzZWFyY2h8M3x8bW9kZXJuJTIwYXJjaGl0ZWN0dXJhbCUyMGludGVyaW9yJTIwc2hvd3Jvb218ZW58MHx8fHwxNzcyOTc0MDY4fDA&amp;ixlib=rb-4.1.0&amp;q=80&amp;w=1600" alt="Showroom architectural moderne"/>
                        <div class="impact-banner-slide__shade"></div>
                        <div class="impact-banner-slide__inner">
                            <div class="impact-banner-slide__content">
                                <span class="impact-banner-slide__eyebrow">Produits &amp; Détail</span>
                                <h2>La précision du détail,<br /><em>le service en plus</em></h2>
                                <p>Profilés, quincaillerie, moustiquaires et accessoires: une offre complète pour accompagner vos chantiers avec réactivité et exigence.</p>
                            </div>
                            <div class="impact-banner-slide__rail">
                                <a href="/about">Découvrir Impact Africa</a>
                                <a href="/blog">Lire nos conseils chantier</a>
                                <a href="/web/login?redirect=/my">Accéder à votre espace pro</a>
                            </div>
                        </div>
                    </article>
                </div>
                <div class="impact-banner-carousel__controls o_not_editable" contenteditable="false">
                    <button type="button" class="impact-banner-carousel__arrow" data-impact-prev="true" aria-label="Slide précédente">
                        <iconify-icon icon="mdi:arrow-left"></iconify-icon>
                    </button>
                    <div class="impact-banner-carousel__dots" aria-label="Navigation du carousel">
                        <button type="button" class="impact-banner-carousel__dot is-active" data-impact-dot="0" aria-current="true" aria-label="Aller au slide 1"></button>
                        <button type="button" class="impact-banner-carousel__dot" data-impact-dot="1" aria-current="false" aria-label="Aller au slide 2"></button>
                        <button type="button" class="impact-banner-carousel__dot" data-impact-dot="2" aria-current="false" aria-label="Aller au slide 3"></button>
                    </div>
                    <button type="button" class="impact-banner-carousel__arrow" data-impact-next="true" aria-label="Slide suivante">
                        <iconify-icon icon="mdi:arrow-right"></iconify-icon>
                    </button>
                </div>
            </div>
        </section>
    </template>
</odoo>
