<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="impact_africa_snippet_group" inherit_id="website.snippets" name="Impact Africa Snippets">
        <xpath expr="//snippets[@id='snippet_groups']//t[@snippet-group='custom']" position="after">
            <t snippet-group="impact_africa"
               t-snippet="website.s_snippet_group"
               string="Impact Africa"
               t-thumbnail="/theme_impact_africa/static/src/img/snippets/impact_group.svg"/>
        </xpath>
        <xpath expr="//snippets[@id='snippet_structure']//t[@t-snippet='website.s_banner']" position="after">
            <t t-snippet="theme_impact_africa.s_banner_v1"
               string="Banner V1"
               group="impact_africa"
               t-thumbnail="/theme_impact_africa/static/src/img/snippets/banner_v1_thumb.svg">
                <keywords>impact africa, banner, hero, aluminium, vitrerie, intro, premium, accueil</keywords>
            </t>
            <t t-snippet="theme_impact_africa.s_banner_carousel"
               string="Banner Carousel"
               group="impact_africa"
               t-thumbnail="/theme_impact_africa/static/src/img/snippets/banner_carousel_thumb.svg">
                <keywords>impact africa, carousel, slider, hero, architecture, image, showcase, landing</keywords>
            </t>
        </xpath>
    </template>

